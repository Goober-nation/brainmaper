# ==========================================
# Brainmap AI - Environment Configuration
# Copy this file to .env and replace the values
# ==========================================

# --- Database Credentials ---
DB_NAME=brainmap
DB_USER=postgres
DB_PASSWORD=

# --- Port Mapping (Host:Container) ---
# Change these if you have port conflicts on your host machine
POSTGRES_EXTERNAL_PORT=5433
BACKEND_EXTERNAL_PORT=8080
FRONTEND_EXTERNAL_PORT=5173

# --- AI Configuration ---
# Get your key from Google AI Studio
GEMINI_API_KEY=your_actual_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# How many parent nodes up the tree the AI should remember (1-5 recommended)
CONTEXT_DEPTH=3